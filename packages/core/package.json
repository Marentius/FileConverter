{
  "name": "@fileconverter/core",
  "version": "1.0.0",
  "description": "Core CLI og bibliotek for FileConverter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "converter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/adapters",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:e2e": "jest --testPathPattern=test/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:all": "node test/run-all-tests.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist coverage",
    "start": "node dist/cli.js",
    "prepack": "npm run build && npm run test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "file-type": "^18.7.0",
    "glob": "^10.3.10",
    "ora": "^7.0.1",
    "p-queue": "^7.4.1",
    "winston": "^3.19.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "rimraf": "^5.0.5",
    "tsup": "^8.5.1"
  },
  "keywords": [
    "file-converter",
    "cli",
    "batch",
    "conversion"
  ],
  "license": "MIT"
}
