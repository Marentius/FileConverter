{
  "name": "@fileconverter/core",
  "version": "1.2.0",
  "description": "Universal file conversion CLI and library — images, documents, PDFs, and OCR with pure npm packages",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "converter": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marentius/FileConverter.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Marentius/FileConverter#readme",
  "bugs": {
    "url": "https://github.com/Marentius/FileConverter/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/adapters",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:e2e": "jest --testPathPattern=test/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:all": "node test/run-all-tests.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rimraf dist coverage",
    "start": "node dist/cli.js",
    "prepack": "npm run build && npm run test"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "file-type": "^21.3.1",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.4",
    "p-queue": "^9.1.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.57.0"
  },
  "keywords": [
    "file-converter",
    "cli",
    "batch",
    "conversion",
    "image",
    "pdf",
    "ocr",
    "sharp",
    "markdown",
    "html"
  ],
  "license": "MIT"
}
